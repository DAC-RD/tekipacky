generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Mode {
  EASY
  NORMAL
  HARD
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  timezone      String       @default("Asia/Tokyo") // IANA タイムゾーン文字列
  points        Int          @default(0)
  mode          Mode         @default(NORMAL)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  actions       Action[]
  rewards       Reward[]
  doneActions   DoneAction[]
  doneRewards   DoneReward[]
  sessions      Session[]
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// 行動マスタ（ユーザーが登録するやること一覧）
model Action {
  id          Int          @id @default(autoincrement())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  desc        String       @default("")
  tags        String[]     // PostgreSQL text[] 型にマップ
  hurdle      Int          // 1〜3: 面倒くささ
  time        Int          // 1〜6: かかる時間
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  doneActions DoneAction[]

  @@index([userId])
}

// ご褒美マスタ
model Reward {
  id           Int          @id @default(autoincrement())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  desc         String       @default("")
  tags         String[]
  satisfaction Int          // 1〜3: 満足度
  time         Int          // 1〜6: かかる時間
  price        Int          // 1〜6: 金額
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  doneRewards  DoneReward[]

  @@index([userId])
}

// 行動完了ログ
// - actionId は nullable: 行動を削除しても過去の履歴を保持するため
// - date は User.timezone での "YYYY-MM-DD"（日をまたいだらこの date で当日分のみ取得）
// - @@unique により同日・同行動のレコードは1つだけ（count で回数を管理）
model DoneAction {
  id       Int     @id @default(autoincrement())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionId Int?
  action   Action? @relation(fields: [actionId], references: [id], onDelete: SetNull)
  title    String  // 行動削除・リネーム後も表示できるようタイトルをスナップショット
  pt       Int
  count    Int
  date     String  // User.timezone での "YYYY-MM-DD"

  @@unique([userId, actionId, date])
  @@index([userId, date])
}

// ご褒美使用ログ
model DoneReward {
  id       Int     @id @default(autoincrement())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId Int?
  reward   Reward? @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  title    String
  pt       Int
  count    Int
  date     String  // User.timezone での "YYYY-MM-DD"

  @@unique([userId, rewardId, date])
  @@index([userId, date])
}
